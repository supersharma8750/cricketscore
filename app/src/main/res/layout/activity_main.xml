<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- APP TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏏 Cricket Scorer Pro"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Match • Track Live • Analyze Game"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"/>

        <!-- MATCH CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1B263B"
            android:padding="20dp"
            android:elevation="8dp">

            <!-- SECTION TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Match Setup"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFD54F"
                android:layout_marginBottom="15dp"/>

            <!-- TEAM A -->
            <EditText
                android:id="@+id/teamA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Team A Name"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:padding="14dp"
                android:background="#0D1B2A"
                android:layout_marginBottom="12dp"/>

            <!-- TEAM B -->
            <EditText
                android:id="@+id/teamB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Team B Name"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:padding="14dp"
                android:background="#0D1B2A"
                android:layout_marginBottom="12dp"/>

            <!-- OVERS -->
            <EditText
                android:id="@+id/overs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Overs (e.g. 5, 10, 20)"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:padding="14dp"
                android:background="#0D1B2A"/>
        </LinearLayout>

        <!-- EXTRA INFO CARD (UI ONLY, no logic change) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1B263B"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Match Type"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="T20 Match"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Venue"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Local Ground"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- START BUTTON -->
        <Button
            android:id="@+id/startBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 START MATCH"
            android:onClick="startMatch"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="#673AB7"
            android:layout_marginTop="30dp"
            android:padding="16dp"/>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Built for Cricket Lovers ❤️"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>