<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:padding="12dp">

    <!-- TEAM -->
    <TextView
        android:id="@+id/teamName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TEAM A"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:gravity="center"/>

    <!-- SCORE -->
    <TextView
        android:id="@+id/scoreText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0/0"
        android:textSize="40sp"
        android:textColor="#00E676"
        android:gravity="center"/>

    <!-- OVERS -->
    <TextView
        android:id="@+id/overText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Overs: 0.0"
        android:textColor="#FFFFFF"
        android:gravity="center"/>

    <!-- WICKETS -->
    <TextView
        android:id="@+id/wicketText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wickets: 0"
        android:textColor="#FFFFFF"
        android:gravity="center"/>

    <!-- TARGET -->
    <TextView
        android:id="@+id/targetText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFD54F"
        android:gravity="center"/>

    <!-- 🔥 CRR -->
    <TextView
        android:id="@+id/crrText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CRR: 0.00"
        android:textColor="#FFFFFF"
        android:gravity="center"/>

    <!-- 🔥 RRR -->
    <TextView
        android:id="@+id/rrrText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RRR: 0.00"
        android:textColor="#FF5252"
        android:gravity="center"
        android:layout_marginBottom="5dp"/>

    <!-- 🔥 BOWLER SPINNER -->
    <Spinner
        android:id="@+id/bowlerSpinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="5dp"/>

    <!-- 🔥 PLAYER LIST (SCROLLABLE) -->
    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/playerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- 🔥 BUTTON SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <Button
                android:text="1"
                android:onClick="addOne"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"/>

            <Button
                android:text="2"
                android:onClick="addTwo"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"/>

            <Button
                android:text="4"
                android:onClick="addFour"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"/>
        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <Button
                android:text="6"
                android:onClick="addSix"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"/>

            <Button
                android:text="W"
                android:onClick="addWicket"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"/>

            <Button
                android:text="WD"
                android:onClick="addWide"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7B1FA2"/>
        </LinearLayout>

        <!-- NEXT INNINGS -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="NEXT INNINGS"
            android:onClick="nextInnings"
            android:backgroundTint="#FF9800"
            android:textColor="#000000"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

</LinearLayout>