<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:padding="16dp">

    <!-- TEAM NAME -->
    <TextView
        android:id="@+id/teamName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TEAM A"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_centerHorizontal="true" />

    <!-- SCORE -->
    <TextView
        android:id="@+id/scoreText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/0"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#00E676"
        android:layout_below="@id/teamName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp" />

    <!-- OVERS -->
    <TextView
        android:id="@+id/overText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overs: 0.0"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:layout_below="@id/scoreText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp" />

    <!-- WICKETS -->
    <TextView
        android:id="@+id/wicketText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wickets: 0"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:layout_below="@id/overText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"/>

    <!-- TARGET -->
    <TextView
        android:id="@+id/targetText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textColor="#FFD54F"
        android:layout_below="@id/wicketText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"/>

    <!-- BOWLER DROPDOWN -->
    <Spinner
        android:id="@+id/bowlerSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/targetText"
        android:layout_marginTop="10dp"/>

    <!-- PLAYER LIST -->
    <ScrollView
        android:id="@+id/playerScroll"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_below="@id/bowlerSpinner"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:id="@+id/playerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- BUTTON SECTION -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/playerScroll"
        android:orientation="vertical"
        android:layout_marginTop="20dp">

        <!-- CRR -->
        <TextView
            android:id="@+id/crrText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRR: 0.00"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"/>

        <!-- RRR -->
        <TextView
            android:id="@+id/rrrText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RRR: 0.00"
            android:textColor="#FF5252"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"/>

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <Button
                android:text="1"
                android:onClick="addOne"
                style="@style/ScoreButton"/>

            <Button
                android:text="2"
                android:onClick="addTwo"
                style="@style/ScoreButton"/>

            <Button
                android:text="4"
                android:onClick="addFour"
                style="@style/ScoreButton"/>
        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:text="6"
                android:onClick="addSix"
                style="@style/ScoreButton"/>

            <Button
                android:text="W"
                android:onClick="addWicket"
                style="@style/ScoreButtonRed"/>

            <Button
                android:text="WD"
                android:onClick="addWide"
                style="@style/ScoreButtonBlue"/>
        </LinearLayout>
    </LinearLayout>

    <!-- NEXT INNINGS -->
    <Button
        android:id="@+id/nextBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEXT INNINGS"
        android:onClick="nextInnings"
        android:layout_below="@id/buttonLayout"
        android:layout_marginTop="15dp"
        android:background="#FF9800"
        android:textColor="#FFFFFF"/>

</RelativeLayout>