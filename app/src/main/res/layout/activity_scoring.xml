<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TEAM -->
        <TextView
            android:id="@+id/teamName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEAM A"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"/>

        <!-- SCORE -->
        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#00E676"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"/>

        <!-- OVER -->
        <TextView
            android:id="@+id/overText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overs: 0.0"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"/>

        <!-- WICKETS -->
        <TextView
            android:id="@+id/wicketText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wickets: 0"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"/>

        <!-- TARGET -->
        <TextView
            android:id="@+id/targetText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD54F"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"/>

        <!-- BOWLER SPINNER -->
        <Spinner
            android:id="@+id/bowlerSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- PLAYER LIST -->
        <ScrollView
            android:id="@+id/playerScroll"
            android:layout_width="wrap_content"
            android:layout_height="140dp"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/playerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <!-- CRR -->
        <TextView
            android:id="@+id/crrText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRR: 0.00"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"/>

        <!-- RRR -->
        <TextView
            android:id="@+id/rrrText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RRR: 0.00"
            android:textColor="#FF5252"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"/>

        <!-- ================= BUTTON GRID ================= -->

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:text="1"
                android:onClick="addOne"
                style="@style/ScoreBtn"/>

            <Button
                android:text="2"
                android:onClick="addTwo"
                style="@style/ScoreBtn"/>

            <Button
                android:text="4"
                android:onClick="addFour"
                style="@style/ScoreBtnGreen"/>
        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp">

            <Button
                android:text="6"
                android:onClick="addSix"
                style="@style/ScoreBtnDarkGreen"/>

            <Button
                android:text="W"
                android:onClick="addWicket"
                style="@style/ScoreBtnRed"/>

            <Button
                android:text="WD"
                android:onClick="addWide"
                style="@style/ScoreBtnBlue"/>
        </LinearLayout>

        <!-- ROW 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp">

            <Button
                android:text="NB"
                android:onClick="addNoBall"
                style="@style/ScoreBtnOrange"/>

            <Button
                android:text="BYE"
                android:onClick="addByes"
                style="@style/ScoreBtnBrown"/>

            <Button
                android:text="RO"
                android:onClick="addRunOut"
                style="@style/ScoreBtnPurple"/>
        </LinearLayout>

        <!-- SWAP -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SWAP (DOT BALL)"
            android:onClick="manualSwap"
            android:background="#455A64"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"/>

        <!-- UNDO -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UNDO"
            android:onClick="undo"
            android:background="#FF5252"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"/>

        <!-- NEXT INNINGS -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="NEXT INNINGS"
            android:onClick="nextInnings"
            android:background="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginTop="15dp"/>

    </LinearLayout>
</ScrollView>