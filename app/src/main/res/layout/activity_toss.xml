<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0D1B2A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MATCH TITLE -->
    <TextView
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:id="@+id/matchTitle"
        android:text="TEAM A vs TEAM B"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- CARD STYLE BOX -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#1B263B"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TOSS -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Who won the toss?"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <RadioGroup
            android:id="@+id/tossGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/teamARadio"
                android:textColor="#FFF"/>

            <RadioButton
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/teamBRadio"
                android:textColor="#FFF"/>
        </RadioGroup>

        <!-- DECISION -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Decision"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <RadioGroup
            android:id="@+id/decisionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/batRadio"
                android:text="Bat"
                android:textColor="#FFF"/>

            <RadioButton
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/bowlRadio"
                android:text="Bowl"
                android:textColor="#FFF"/>
        </RadioGroup>

    </LinearLayout>

    <!-- START BUTTON -->
    <Button
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="START MATCH"
        android:onClick="startMatch"
        android:background="#00E676"
        android:textColor="#000"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:padding="12dp"/>
</LinearLayout>